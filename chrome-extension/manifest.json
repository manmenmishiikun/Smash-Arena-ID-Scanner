{
  "manifest_version": 3,
  "name": "Smash Arena ID Bridge",
  "version": "1.1.8",
  "description": "PC の Arena Scan で確定した部屋 ID を、スマメイトの対戦ルーム画面へ渡す連携拡張です。",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://smashmate.net/rate/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html",
    "default_title": "Arena Scan 連携 — 設定",
    "default_icon": {
      "16": "icons/action-red-16.png",
      "32": "icons/action-red-32.png",
      "48": "icons/action-red-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://smashmate.net/rate/*"],
      "js": ["shared-path.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
