{
  "manifest_version": 3,
  "name": "Smash Arena ID Bridge",
  "version": "1.1.3",
  "description": "Smash Arena ID Scanner のローカル SSE から部屋コードを受け取り、スマメイトの rate ページの入力欄へ反映します。",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://smashmate.net/rate/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html",
    "default_title": "Smash Arena ID Bridge — 設定"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["https://smashmate.net/rate/*"],
      "js": ["shared-path.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
